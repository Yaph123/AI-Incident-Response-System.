# Copy to .env in project root

# Database & queue
DATABASE_URL=postgresql+psycopg://incident:incident@localhost:5433/incident_response
REDIS_URL=redis://localhost:6379/0

# OpenAI (optional — falls back to structured stubs when unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Slack (optional — logs locally when unset)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#incidents

# GitHub (optional — returns empty context when unset)
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=

# App
LOG_LEVEL=INFO
REQUIRE_APPROVAL_FOR_SLACK=false
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
